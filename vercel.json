{
  "version": 2,
  "buildCommand": "npm install",
  "functions": {
    "api/server.js": {
      "memory": 128,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api(.*)", "destination": "/api/server.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}